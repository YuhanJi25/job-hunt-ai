# JobMatch AI Demo Configuration

# Docker Hub Username (REQUIRED)
# Replace with your Docker Hub username where the images are hosted
DOCKER_USERNAME=YOUR_DOCKERHUB_USERNAME

# Anthropic API Key (OPTIONAL)
# Required for AI-powered job explanations and reranking
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Database Credentials (DO NOT CHANGE for demo)
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Semantic embedding settings
SENTENCE_TRANSFORMER_MODEL=BAAI/bge-m3
SEMANTIC_EMBEDDING_MODEL=BAAI/bge-m3
SEMANTIC_EMBEDDING_DEVICE=cpu
SEMANTIC_EMBEDDING_BATCH_SIZE=16
SEMANTIC_EMBEDDING_NORMALIZE=true
SEMANTIC_EMBEDDING_TRUST_REMOTE_CODE=true
SEMANTIC_INDEX_PATH=artifacts/semantic_index/jobs_embeddings.npy
SEMANTIC_INDEX_IDS=artifacts/semantic_index/jobs_embedding_ids.json
TOKENIZERS_PARALLELISM=false

# Application Ports (change if you have conflicts)
FRONTEND_PORT=18080
# BACKEND_PORT=8000
# ELASTICSEARCH_PORT=9200
# NEO4J_BROWSER_PORT=7474
# NEO4J_BOLT_PORT=7687
